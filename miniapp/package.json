    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@babel/runtime": "^7.24.0",
    "@tarojs/cli": "4.0.7",
    "@tarojs/webpack5-runner": "4.0.7",
    "@types/react": "^18.3.0",
    "typescript": "^5.5.0",
